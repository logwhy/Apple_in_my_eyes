<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">

  <BehaviorTree ID="check_game_start">
    <Fallback>
      <IsGameStatus name="IsGameStart"
                    max_remain_time="420"
                    min_remain_time="0"
                    expected_game_progress="4"
                    key_port="{@referee_gameStatus}"/>

      <ForceFailure>
        <Sequence>
          <PublishSpinSpeed spin_speed="0.0"
                            duration="0.0"
                            topic_name="cmd_spin"/>
          <PublishTwist v_y="0.0"
                        v_yaw="0.0"
                        v_x="0.0"
                        duration="0.0"
                        topic_name="cmd_vel"/>
          <SetSentryCmd posture_command="3"
                        topic_name="sentry_cmd"/>

          <IsAttackState mode="reset"
                        topic_name="cmd_gimbal"
                        detect_timeout_ms="500"
                        no_enemy_timeout_s="60.0"
                        min_attack_duration_s="180.0"/>
        </Sequence>
      </ForceFailure>
    </Fallback>
  </BehaviorTree>

  <BehaviorTree ID="rmuc_2026">
    <KeepRunningUntilFailure>
      <ForceSuccess>
        <ReactiveSequence>

          <SubTree ID="check_game_start"/>

          <ReactiveFallback>

            <!-- 1. 死亡且可免费复活：只确认复活 -->
            <Sequence>
              <IsDead key_port="{@referee_robotStatus}"/>
              <CanFreeRespawn key_port="{@referee_sentryInfo}"/>
              <SetSentryCmd confirm_respawn="true"
                            topic_name="sentry_cmd"/>
            </Sequence>

            <!-- 3. 已经在补给区 + HP 小于 360：原地等待规则自动回血，不兑换弹丸、不请求回血、不切姿态 -->
            <Sequence>
              <IsRfidDetected friendly_supply_zone_exchange="true"
                              friendly_supply_zone_non_exchange="true"
                              center_gain_point="false"
                              friendly_fortress_gain_point="false"
                              key_port="{@referee_rfidStatus}"/>

              <Inverter>
                <IsStatusOK hp_min="360"
                            heat_max="999"
                            ammo_min="0"
                            key_port="{@referee_robotStatus}"/>
              </Inverter>

              <IsAttackState mode="reset"
                             topic_name="cmd_gimbal"
                             detect_timeout_ms="500"
                             no_enemy_timeout_s="60.0"
                             min_attack_duration_s="180.0"/>

              <PublishSpinSpeed spin_speed="7.0"
                                duration="0.0"
                                topic_name="cmd_spin"/>
            </Sequence>

            <!-- 2. 已经在补给区 + 弹丸少于 50：本次补给区访问只兑换一次；每次重新回补给区，兑弹量 +1 -->
            <Sequence>
            <ExchangeProjectileOnce
              rfid_key_port="{@referee_rfidStatus}"
              robot_status_key_port="{@referee_robotStatus}"
              friendly_supply_zone_exchange="true"
              friendly_supply_zone_non_exchange="true"
              ammo_threshold="50"
              min_gold="150"
              base_exchange="150"
              increment_step="1"
              max_exchange="200"
              topic_name="sentry_cmd"/>

              <PublishSpinSpeed spin_speed="7.0"
                                duration="0.0"
                                topic_name="cmd_spin"/>
            </Sequence>



            <!-- 4. HP 小于等于 120 且不在补给区：最高优先级，直接切移动姿态回补给区 -->
            <Sequence>
              <Inverter>
                <IsStatusOK hp_min="121"
                            heat_max="999"
                            ammo_min="0"
                            key_port="{@referee_robotStatus}"/>
              </Inverter>

              <Inverter>
                <IsRfidDetected friendly_supply_zone_exchange="true"
                                friendly_supply_zone_non_exchange="true"
                                center_gain_point="false"
                                friendly_fortress_gain_point="false"
                                key_port="{@referee_rfidStatus}"/>
              </Inverter>

              <IsAttackState mode="reset"
                             topic_name="cmd_gimbal"
                             detect_timeout_ms="500"
                             no_enemy_timeout_s="60.0"
                             min_attack_duration_s="180.0"/>

              <SetSentryCmd posture_command="3"
                            topic_name="sentry_cmd"/>

              <PublishSpinSpeed spin_speed="7.0"
                                duration="0.0"
                                topic_name="cmd_spin"/>

              <!-- 补给区点位：改补给区目标点就改这里 -->
              <PubNav2Goal goal="-1.7;-6.2;0"
                           topic_name="goal_pose"/>
            </Sequence>

            <!-- 5. 弹丸少于 50 且不在补给区：回补给区补弹，但不额外切姿态 -->
            <Sequence>
              <Inverter>
                <IsStatusOK hp_min="0"
                            heat_max="999"
                            ammo_min="50"
                            key_port="{@referee_robotStatus}"/>
              </Inverter>

              <IsGoldCoinEnough min_gold="150"
                                key_port="{@referee_robotStatus}"/>

              <Inverter>
                <IsRfidDetected friendly_supply_zone_exchange="true"
                                friendly_supply_zone_non_exchange="true"
                                center_gain_point="false"
                                friendly_fortress_gain_point="false"
                                key_port="{@referee_rfidStatus}"/>
              </Inverter>

              <IsAttackState mode="reset"
                             topic_name="cmd_gimbal"
                             detect_timeout_ms="500"
                             no_enemy_timeout_s="60.0"
                             min_attack_duration_s="180.0"/>

              <SetSentryCmd posture_command="3"
                            topic_name="sentry_cmd"/>

              <PublishSpinSpeed spin_speed="7.0"
                                duration="0.0"
                                topic_name="cmd_spin"/>

              <!-- 补给区点位：改补弹目标点就改这里 -->
              <PubNav2Goal goal="-1.7;-6.2;0"
                           topic_name="goal_pose"/>
            </Sequence>

            <!-- 7. 当前看到敌人：只切进攻姿态 + 高速小陀螺，不负责发导航点 -->
            <Sequence>
              <IsAttackState mode="enemy_visible"
                             topic_name="cmd_gimbal"
                             detect_timeout_ms="500"
                             no_enemy_timeout_s="60.0"
                             min_attack_duration_s="180.0"/>

              <SetSentryCmd posture_command="1"
                            topic_name="sentry_cmd"/>

              <PublishSpinSpeed spin_speed="8.0"
                                duration="0.0"
                                topic_name="cmd_spin"/>

              <PubNav2Goal goal="4.88;-0.59;0"
                           map_command="{@map_command}"
                           map_command_team="red"
                           map_command_red_origin_x="3.9"
                           map_command_red_origin_y="8.087"
                           map_command_blue_origin_x="26.0"
                           map_command_blue_origin_y="6.0"
                           map_command_offset_x="0.0"
                           map_command_offset_y="0.0"
                           map_command_yaw="0.0"
                           topic_name="goal_pose"/>
            </Sequence>

            <!-- 8. 处于进攻保持窗口：继续保持进攻姿态，小陀螺 14 rad/s -->
            <Sequence>
              <IsAttackState mode="keep_attack"
                             topic_name="cmd_gimbal"
                             detect_timeout_ms="500"
                             no_enemy_timeout_s="60.0"
                             min_attack_duration_s="180.0"/>

              <SetSentryCmd posture_command="1"
                            topic_name="sentry_cmd"/>

              <PublishSpinSpeed spin_speed="8.0"
                                duration="0.0"
                                topic_name="cmd_spin"/>

              <PubNav2Goal goal="4.88;-0.59;0"
                           map_command="{@map_command}"
                           map_command_team="red"
                           map_command_red_origin_x="3.879"
                           map_command_red_origin_y="8.087"
                           map_command_blue_origin_x="26.0"
                           map_command_blue_origin_y="6.0"
                           map_command_offset_x="0.0"
                           map_command_offset_y="0.0"
                           map_command_yaw="0.0"
                           topic_name="goal_pose"/>
            </Sequence>

                        <!-- 8.5 进攻状态下尝试追击；失败则回退到后续常态点 -->
            <!-- <Sequence>
              <ReactiveFallback>
                <IsAttackState mode="enemy_visible"
                               topic_name="cmd_gimbal"
                               detect_timeout_ms="500"
                               no_enemy_timeout_s="60.0"
                               min_attack_duration_s="180.0"/>

                <IsAttackState mode="keep_attack"
                               topic_name="cmd_gimbal"
                               detect_timeout_ms="500"
                               no_enemy_timeout_s="60.0"
                               min_attack_duration_s="180.0"/>
              </ReactiveFallback>

              <SetSentryCmd posture_command="1"
                            topic_name="sentry_cmd"/>

              <PublishSpinSpeed spin_speed="7.0"
                                duration="0.0"
                                topic_name="cmd_spin"/>

              <CalculateChaseGoal
                topic_name="/target_xyz_camera"
                source_frame="front_industrial_camera_optical_frame"
                world_frame="odom"
                robot_base_frame="chassis"
                target_timeout="0.35"
                chase_distance="1.5"
                stop_tolerance="0.15"
                z_min="0.8"
                z_max="6.0"
                x_abs_max="2.5"
                y_abs_max="1.5"
                goal_x_min="-2.0"
                goal_x_max="5.0"
                goal_y_min="-6.2"
                goal_y_max="1.8"
                transform_tolerance="0.2"
                goal="{chase_goal}"/>

              <PubNav2Goal goal_pose="{chase_goal}"
                           frame_id="odom"
                           topic_name="goal_pose"/>
            </Sequence> -->
            <!-- 6. 3 秒内扣血大于 40：高速小陀螺 10 秒，不切姿态 -->
            <Sequence>
              <IsHpDecreased window_s="3.0"
                             drop_threshold="40"
                             hold_s="10.0"
                             key_port="{@referee_robotStatus}"/>

              <PublishSpinSpeed spin_speed="14.0"
                                duration="0.0"
                                topic_name="cmd_spin"/>

              <PubNav2Goal goal="4.88;-0.59;0"
                           map_command="{@map_command}"
                           map_command_team="red"
                           map_command_red_origin_x="3.879"
                           map_command_red_origin_y="8.087"
                           map_command_blue_origin_x="26.0"
                           map_command_blue_origin_y="6.0"
                           map_command_offset_x="0.0"
                           map_command_offset_y="0.0"
                           map_command_yaw="0.0"
                           topic_name="goal_pose"/>
            </Sequence>

            <!-- 9. 1 分钟没敌人 + 进攻超过 3 分钟 + HP 大于 200：切防御姿态 -->
            <Sequence>
              <IsAttackState mode="can_leave"
                             topic_name="cmd_gimbal"
                             detect_timeout_ms="500"
                             no_enemy_timeout_s="60.0"
                             min_attack_duration_s="180.0"/>

              <IsStatusOK hp_min="201"
                          heat_max="999"
                          ammo_min="0"
                          key_port="{@referee_robotStatus}"/>

              <SetSentryCmd posture_command="2"
                            topic_name="sentry_cmd"/>

              <PublishSpinSpeed spin_speed="10.0"
                                duration="0.0"
                                topic_name="cmd_spin"/>
            </Sequence>

            <!-- 10. 1 分钟没敌人 + 进攻超过 3 分钟 + HP 小于 200：切移动姿态，回补给区 -->
            <Sequence>
              <IsAttackState mode="can_leave"
                             topic_name="cmd_gimbal"
                             detect_timeout_ms="500"
                             no_enemy_timeout_s="60.0"
                             min_attack_duration_s="180.0"/>

              <Inverter>
                <IsStatusOK hp_min="200"
                            heat_max="999"
                            ammo_min="0"
                            key_port="{@referee_robotStatus}"/>
              </Inverter>

              <SetSentryCmd posture_command="3"
                            topic_name="sentry_cmd"/>

              <PublishSpinSpeed spin_speed="7.0"
                                duration="0.0"
                                topic_name="cmd_spin"/>

              <!-- 补给区点位：改撤退目标点就改这里 -->
              <PubNav2Goal goal="-1.7;-6.2;0"
                           topic_name="goal_pose"/>
            </Sequence>

            <!-- 11. 比赛开始 + 状态良好：常态去巡逻/进攻待机点，小陀螺 7 rad/s -->
            <Sequence>
              <IsStatusOK hp_min="121"
                          heat_max="350"
                          ammo_min="50"
                          key_port="{@referee_robotStatus}"/>

              <SetSentryCmd posture_command="3"
                            topic_name="sentry_cmd"/>

              <PublishSpinSpeed spin_speed="14.0"
                                duration="0.0"
                                topic_name="cmd_spin"/>

              <!-- 常态巡逻/进攻待机点：改这里，不再依赖发现敌人 -->
              <PubNav2Goal goal="4.88;-0.59;0"
                           map_command="{@map_command}"
                           map_command_team="red"
                           map_command_red_origin_x="3.879"
                           map_command_red_origin_y="8.087"
                           map_command_blue_origin_x="26.0"
                           map_command_blue_origin_y="6.0"
                           map_command_offset_x="0.0"
                           map_command_offset_y="0.0"
                           map_command_yaw="0.0"
                           topic_name="goal_pose"/>
            </Sequence>

            <!-- 12. 兜底：移动姿态 + 巡逻点，避免低弹但金币不足时只转不走 -->
            <Sequence>
              <SetSentryCmd posture_command="3"
                            topic_name="sentry_cmd"/>

              <PublishSpinSpeed spin_speed="14.0"
                                duration="0.0"
                                topic_name="cmd_spin"/>

              <PubNav2Goal goal="4.88;-0.59;0"
                          map_command="{@map_command}"
                          map_command_team="red"
                           map_command_red_origin_x="3.879"
                           map_command_red_origin_y="8.087"
                          map_command_blue_origin_x="26.0"
                          map_command_blue_origin_y="6.0"
                          map_command_offset_x="0.0"
                          map_command_offset_y="0.0"
                          map_command_yaw="0.0"
                          topic_name="goal_pose"/>
            </Sequence>

          </ReactiveFallback>
        </ReactiveSequence>
      </ForceSuccess>
    </KeepRunningUntilFailure>
  </BehaviorTree>

  <TreeNodesModel>

    <Condition ID="IsGameStatus">
      <input_port name="max_remain_time" default="420" type="int">Maximum remaining time in seconds</input_port>
      <input_port name="min_remain_time" default="0" type="int">Minimum remaining time in seconds</input_port>
      <input_port name="expected_game_progress" default="4" type="int">Expected game progress stage</input_port>
      <input_port name="key_port" default="{@referee_gameStatus}">GameStatus port on blackboard</input_port>
    </Condition>

    <Condition ID="IsRfidDetected">
      <input_port name="friendly_supply_zone_exchange" default="false" type="bool">Friendly supply zone exchange</input_port>
      <input_port name="friendly_supply_zone_non_exchange" default="false" type="bool">Friendly supply zone non exchange</input_port>
      <input_port name="center_gain_point" default="false" type="bool">Center gain point</input_port>
      <input_port name="friendly_fortress_gain_point" default="false" type="bool">Friendly fortress gain point</input_port>
      <input_port name="key_port" default="{@referee_rfidStatus}">RfidStatus port on blackboard</input_port>
    </Condition>

    <Condition ID="IsStatusOK">
      <input_port name="ammo_min" default="0" type="int">Minimum projectile allowance</input_port>
      <input_port name="heat_max" default="350" type="int">Maximum shooter heat</input_port>
      <input_port name="hp_min" default="300" type="int">Minimum HP</input_port>
      <input_port name="key_port" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
    </Condition>

    <Condition ID="IsGoldCoinEnough">
      <input_port name="key_port" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
      <input_port name="min_gold" default="150" type="int">Minimum remaining gold coin</input_port>
    </Condition>

    <Condition ID="IsDead">
      <input_port name="key_port" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
    </Condition>

    <Condition ID="CanFreeRespawn">
      <input_port name="key_port" default="{@referee_sentryInfo}">SentryInfo port on blackboard</input_port>
    </Condition>

    <Condition ID="IsHpLessThan">
      <input_port name="key_port" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
      <input_port name="threshold" type="double">HP ratio threshold</input_port>
    </Condition>

    <Condition ID="IsHpDecreased">
      <input_port name="key_port" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
      <input_port name="window_s" default="3.0" type="double">HP drop detect window</input_port>
      <input_port name="drop_threshold" default="40" type="int">HP drop threshold</input_port>
      <input_port name="hold_s" default="10.0" type="double">Hold success duration</input_port>
    </Condition>

    <Condition ID="IsAttackState">
      <input_port name="mode" default="keep_attack" type="std::string">enemy_visible / keep_attack / can_leave / reset</input_port>
      <input_port name="topic_name" default="cmd_gimbal" type="std::string">Gimbal command topic</input_port>
      <input_port name="detect_timeout_ms" default="500" type="int">Enemy detection timeout</input_port>
      <input_port name="no_enemy_timeout_s" default="60.0" type="double">No enemy timeout</input_port>
      <input_port name="min_attack_duration_s" default="180.0" type="double">Minimum attack duration</input_port>
    </Condition>

    <Action ID="PubNav2Goal">
      <input_port name="goal" default="0;0;0" type="std::string">Goal in x;y;yaw format</input_port>
      <input_port name="map_command" default="{@map_command}">Map command point from /mapcommand</input_port>
      <input_port name="map_command_team" default="red" type="std::string">red or blue map command transform</input_port>
      <input_port name="map_command_red_origin_x" default="2.6" type="double">Red origin X in field coordinates</input_port>
      <input_port name="map_command_red_origin_y" default="9.1" type="double">Red origin Y in field coordinates</input_port>
      <input_port name="map_command_blue_origin_x" default="26.0" type="double">Blue origin X in field coordinates</input_port>
      <input_port name="map_command_blue_origin_y" default="6.0" type="double">Blue origin Y in field coordinates</input_port>
      <input_port name="map_command_offset_x" default="0.0" type="double">Offset added to map command X</input_port>
      <input_port name="map_command_offset_y" default="0.0" type="double">Offset added to map command Y</input_port>
      <input_port name="map_command_yaw" default="0.0" type="double">Yaw used for map command goal</input_port>
      <input_port name="topic_name" default="goal_pose" type="std::string">Topic name</input_port>
    </Action>

    <Action ID="PublishSpinSpeed">
      <input_port name="spin_speed" default="0.0" type="double">Angular Z velocity</input_port>
      <input_port name="duration" default="0.0">Publish duration</input_port>
      <input_port name="topic_name" default="cmd_spin" type="std::string">Topic name</input_port>
    </Action>

    <Action ID="PublishTwist">
      <input_port name="v_y" default="0.0" type="double">Linear Y velocity</input_port>
      <input_port name="v_yaw" default="0.0" type="double">Angular Z velocity</input_port>
      <input_port name="v_x" default="0.0" type="double">Linear X velocity</input_port>
      <input_port name="duration" default="0.0">Publish duration</input_port>
      <input_port name="topic_name" default="cmd_vel" type="std::string">Topic name</input_port>
    </Action>

    <Action ID="SetSentryCmd">
      <input_port name="confirm_respawn" default="false" type="bool">Confirm free respawn</input_port>
      <input_port name="confirm_pay_respawn" default="false" type="bool">Confirm paid respawn</input_port>
      <input_port name="projectile_allowance_to_exchange" default="0" type="int">Projectile allowance to exchange</input_port>
      <input_port name="remote_projectile_request_count" default="0" type="int">Remote projectile exchange request count</input_port>
      <input_port name="remote_hp_request_count" default="0" type="int">Remote HP exchange request count</input_port>
      <input_port name="posture_command" default="0" type="int">Posture command: 1 attack, 2 defense, 3 move, 0 unchanged</input_port>
      <input_port name="activate_rune" default="false" type="bool">Activate rune</input_port>
      <input_port name="topic_name" default="sentry_cmd" type="std::string">Topic name</input_port>
    </Action>

    <Action ID="ExchangeProjectileOnce">
      <input_port name="rfid_key_port" default="{@referee_rfidStatus}">RfidStatus port on blackboard</input_port>
      <input_port name="robot_status_key_port" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
      <input_port name="friendly_supply_zone_exchange" default="true" type="bool">Use friendly supply zone exchange flag</input_port>
      <input_port name="friendly_supply_zone_non_exchange" default="true" type="bool">Use friendly supply zone non-exchange flag</input_port>
      <input_port name="ammo_threshold" default="50" type="int">Only exchange when projectile allowance is lower than this value</input_port>
      <input_port name="min_gold" default="150" type="int">Minimum remaining gold coin required before exchange</input_port>
      <input_port name="base_exchange" default="150" type="int">First exchange projectile amount</input_port>
      <input_port name="increment_step" default="1" type="int">Increase exchange amount by this value every new supply-zone visit</input_port>
      <input_port name="max_exchange" default="500" type="int">Maximum projectile exchange value clamp</input_port>
      <input_port name="topic_name" default="sentry_cmd" type="std::string">Topic name of SentryCmd</input_port>
      <input_port name="leave_confirm_s" default="1.0" type="double">Supply zone RFID lost duration before confirming leave</input_port>
      <input_port name="exchange_cooldown_s" default="8.0" type="double">Minimum interval between exchange commands</input_port>
    </Action>

  </TreeNodesModel>

</root>
