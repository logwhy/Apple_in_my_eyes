<root BTCPP_format="4">
    <TreeNodesModel>
        <Condition ID="CalculateAttackPose">
            <input_port name="costmap_port" type="nav_msgs::msg::OccupancyGrid_&lt;std::allocator&lt;void&gt; &gt;" default="{@nav_globalCostmap}">GlobalCostmap port on blackboard</input_port>
            <input_port name="tracker_port" type="auto_aim_interfaces::msg::Target_&lt;std::allocator&lt;void&gt; &gt;" default="{@tracker_target}">Vision target port on blackboard</input_port>
            <output_port name="goal" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;" default="{attack_pose}">Expected goal pose that send to nav2. Fill with format `x;y;yaw`</output_port>
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
        </Condition>
        <Action ID="CalculateChaseGoal">
            <input_port name="goal_y_max" type="double" default="100.000000">Goal max y</input_port>
            <input_port name="goal_x_max" type="double" default="100.000000">Goal max x</input_port>
            <input_port name="goal_x_min" type="double" default="-100.000000">Goal min x</input_port>
            <input_port name="world_y_max" type="double" default="100.000000">World max y for target</input_port>
            <input_port name="world_y_min" type="double" default="-100.000000">World min y for target</input_port>
            <output_port name="goal" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;" default="{chase_goal}">Chase goal</output_port>
            <input_port name="topic_name" type="std::string" default="/target_xyz_camera">Vision target topic</input_port>
            <input_port name="source_frame" type="std::string" default="front_industrial_camera_optical_frame">Real source frame used for target point</input_port>
            <input_port name="z_max" type="double" default="6.000000">Maximum valid target depth</input_port>
            <input_port name="world_frame" type="std::string" default="odom">World frame</input_port>
            <input_port name="robot_base_frame" type="std::string" default="chassis">Robot base frame</input_port>
            <input_port name="target_timeout" type="double" default="0.350000">Target timeout in seconds</input_port>
            <input_port name="chase_distance" type="double" default="1.500000">Desired stop distance to target</input_port>
            <input_port name="stop_tolerance" type="double" default="0.150000">Tolerance around chase distance</input_port>
            <input_port name="z_min" type="double" default="0.800000">Minimum valid target depth</input_port>
            <input_port name="x_abs_max" type="double" default="2.500000">Maximum abs x in camera frame</input_port>
            <input_port name="y_abs_max" type="double" default="1.500000">Maximum abs y in camera frame</input_port>
            <input_port name="world_x_max" type="double" default="100.000000">World max x for target</input_port>
            <input_port name="transform_tolerance" type="double" default="0.200000">TF timeout</input_port>
            <input_port name="goal_y_min" type="double" default="-100.000000">Goal min y</input_port>
            <input_port name="world_x_min" type="double" default="-100.000000">World min x for target</input_port>
        </Action>
        <Condition ID="CanFreeRespawn">
            <input_port name="key_port" type="pb_rm_interfaces::msg::SentryInfo_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_sentryInfo}">SentryInfo port on blackboard</input_port>
        </Condition>
        <Action ID="ExchangeProjectileOnce">
            <input_port name="increment_step" type="int" default="1">Increase exchange amount by this value every new supply-zone visit</input_port>
            <input_port name="topic_name" type="std::string" default="sentry_cmd">Topic name of SentryCmd</input_port>
            <input_port name="base_exchange" type="int" default="150">First exchange projectile amount</input_port>
            <input_port name="max_exchange" type="int" default="500">Maximum projectile exchange value clamp</input_port>
            <input_port name="min_gold" type="int" default="150">Do not exchange projectile if remaining_gold_coin is lower than this value</input_port>
            <input_port name="friendly_supply_zone_exchange" type="bool" default="true">Use friendly supply zone exchange flag</input_port>
            <input_port name="ammo_threshold" type="int" default="50">Only exchange when projectile allowance is lower than this value</input_port>
            <input_port name="friendly_supply_zone_non_exchange" type="bool" default="true">Use friendly supply zone non-exchange flag</input_port>
            <input_port name="robot_status_key_port" type="pb_rm_interfaces::msg::RobotStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
            <input_port name="rfid_key_port" type="pb_rm_interfaces::msg::RfidStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_rfidStatus}">RfidStatus port on blackboard</input_port>
        </Action>
        <Condition ID="IsAttackState">
            <input_port name="min_attack_duration_s" type="double" default="180.000000">Minimum attack duration before leaving attack</input_port>
            <input_port name="no_enemy_timeout_s" type="double" default="60.000000">No enemy duration before leaving attack</input_port>
            <input_port name="detect_timeout_ms" type="int" default="500">Enemy visible timeout in milliseconds</input_port>
            <input_port name="topic_name" type="std::string" default="cmd_gimbal">Topic name of gimbal command</input_port>
            <input_port name="mode" type="std::string" default="keep_attack">keep_attack / can_leave / enemy_visible / reset</input_port>
        </Condition>
        <Condition ID="IsAttacked">
            <output_port name="gimbal_yaw" type="float" default="{gimbal_yaw}">Move gimbal_yaw to the direction of the hit armor plate</output_port>
            <output_port name="gimbal_pitch" type="float" default="{gimbal_pitch}">Move gimbal_pitch (const 0.0) to the direction of the hit armor plate</output_port>
            <input_port name="key_port" type="pb_rm_interfaces::msg::RobotStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
        </Condition>
        <Condition ID="IsDead">
            <input_port name="key_port" type="pb_rm_interfaces::msg::RobotStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
        </Condition>
        <Condition ID="IsDetectEnemy">
            <input_port name="timeout_ms" type="int" default="120">If a cmd_gimbal message is received within this timeout, enemy is considered detected</input_port>
            <input_port name="topic_name" type="std::string" default="cmd_gimbal">Topic name of gimbal command</input_port>
        </Condition>
        <Condition ID="IsGameStatus">
            <input_port name="max_remain_time" type="int" default="420">Maximum remaining time (s)</input_port>
            <input_port name="min_remain_time" type="int" default="0">Minimum remaining time (s)</input_port>
            <input_port name="expected_game_progress" type="int" default="4">Expected game progress stage</input_port>
            <input_port name="key_port" type="pb_rm_interfaces::msg::GameStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_gameStatus}">GameStatus port on blackboard</input_port>
        </Condition>
        <Condition ID="IsGoalReachedByOdom">
            <input_port name="goal" type="std::string" default="0;0;0">Goal format: x;y;yaw or x;y;z;yaw</input_port>
            <input_port name="pos_tolerance" type="double" default="0.500000">Position tolerance in meters</input_port>
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
        </Condition>
        <Condition ID="IsGoldCoinEnough">
            <input_port name="min_gold" type="int" default="150">Minimum remaining gold coin</input_port>
            <input_port name="key_port" type="pb_rm_interfaces::msg::RobotStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
        </Condition>
        <Condition ID="IsHpDecreased">
            <input_port name="hold_s" type="double" default="10.000000">Keep SUCCESS after triggered, in seconds</input_port>
            <input_port name="drop_threshold" type="int" default="40">Trigger if HP drop in window is greater than this value</input_port>
            <input_port name="window_s" type="double" default="3.000000">Time window for HP drop detection, in seconds</input_port>
            <input_port name="key_port" type="pb_rm_interfaces::msg::RobotStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
        </Condition>
        <Condition ID="IsHpLessThan">
            <input_port name="threshold" type="double">HP ratio threshold (0.0 ~ 1.0)</input_port>
            <input_port name="key_port" type="pb_rm_interfaces::msg::RobotStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
        </Condition>
        <Condition ID="IsRfidDetected">
            <input_port name="friendly_supply_zone_exchange" type="bool" default="false">己方与兑换区重叠的补给区</input_port>
            <input_port name="friendly_supply_zone_non_exchange" type="bool" default="false">己方与兑换区不重叠的补给区 / RMUL 补给区</input_port>
            <input_port name="center_gain_point" type="bool" default="false">中心增益点（仅 RMUL 适用）</input_port>
            <input_port name="friendly_fortress_gain_point" type="bool" default="false">己方堡垒增益点</input_port>
            <input_port name="key_port" type="pb_rm_interfaces::msg::RfidStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_rfidStatus}">RfidStatus port on blackboard</input_port>
        </Condition>
        <Condition ID="IsStatusOK">
            <input_port name="ammo_min" type="int" default="0">Lower then minimum ammo will return FAILURE</input_port>
            <input_port name="heat_max" type="int" default="370">Maximum heat. NOTE: Sentry heat limit is 400</input_port>
            <input_port name="hp_min" type="int" default="300">Minimum HP. NOTE: Sentry init/max HP is 400</input_port>
            <input_port name="key_port" type="pb_rm_interfaces::msg::RobotStatus_&lt;std::allocator&lt;void&gt; &gt;" default="{@referee_robotStatus}">RobotStatus port on blackboard</input_port>
        </Condition>
        <Condition ID="PubNav2Goal">
            <input_port name="goal" type="std::string" default="0;0;0">Goal in format 'x;y;yaw' or 'x;y;z;yaw'</input_port>
            <input_port name="map_command_offset_y" type="double" default="0.000000">Offset added to map command Y</input_port>
            <input_port name="goal_pose" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;">PoseStamped goal from blackboard</input_port>
            <input_port name="map_command" type="geometry_msgs::msg::Point_&lt;std::allocator&lt;void&gt; &gt;">Map command point from blackboard</input_port>
            <input_port name="map_command_offset_x" type="double" default="0.000000">Offset added to map command X</input_port>
            <input_port name="frame_id" type="std::string" default="map">Frame ID for the goal pose</input_port>
            <input_port name="map_command_team" type="std::string" default="red">red or blue map command transform</input_port>
            <input_port name="map_command_red_origin_x" type="double" default="2.700000">Red origin X in field coordinates</input_port>
            <input_port name="map_command_red_origin_y" type="double" default="9.900000">Red origin Y in field coordinates</input_port>
            <input_port name="map_command_blue_origin_x" type="double" default="26.000000">Blue origin X in field coordinates</input_port>
            <input_port name="map_command_yaw" type="double" default="0.000000">Yaw used for map command goal</input_port>
            <input_port name="map_command_blue_origin_y" type="double" default="6.000000">Blue origin Y in field coordinates</input_port>
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
        </Condition>
        <Action ID="PublishGimbalAbsolute">
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
            <input_port name="duration" type="std::chrono::milliseconds">Publish duration</input_port>
            <input_port name="gimbal_yaw" type="float">Expected Yaw angle (rad)</input_port>
            <input_port name="gimbal_pitch" type="float">Expected Pitch angle (rad)</input_port>
        </Action>
        <Action ID="PublishGimbalVelocity">
            <input_port name="duration" type="std::chrono::milliseconds">Publish duration</input_port>
            <input_port name="yaw_min" type="float" default="-3.140000">Minimum yaw range</input_port>
            <input_port name="pitch_min" type="float" default="-1.570000">Minimum pitch range</input_port>
            <input_port name="yaw_max" type="float" default="3.140000">Maximum yaw range</input_port>
            <input_port name="pitch_max" type="float" default="1.570000">Maximum pitch range</input_port>
            <input_port name="gimbal_vel_yaw" type="float" default="0.000000">Yaw velocity (rad/s)</input_port>
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
            <input_port name="gimbal_vel_pitch" type="float" default="0.000000">Pitch velocity (rad/s)</input_port>
        </Action>
        <Action ID="PublishSpinSpeed">
            <input_port name="spin_speed" type="double" default="0.000000">Angular Z velocity (rad/s)</input_port>
            <input_port name="duration" type="std::chrono::milliseconds" default="">Publish then sleep duration in milliseconds</input_port>
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
        </Action>
        <Action ID="PublishTwist">
            <input_port name="v_y" type="double" default="0.000000">Linear Y velocity (m/s)</input_port>
            <input_port name="v_yaw" type="double" default="0.000000">Angular Z velocity (rad/s)</input_port>
            <input_port name="v_x" type="double" default="0.000000">Linear X velocity (m/s)</input_port>
            <input_port name="duration" type="std::chrono::milliseconds" default="">Publish then sleep duration in milliseconds</input_port>
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
        </Action>
        <Decorator ID="RateController">
            <input_port name="hz" type="double" default="10.000000">Rate</input_port>
        </Decorator>
        <Control ID="RecoveryNode">
            <input_port name="num_attempts" type="int" default="999">Number of retries</input_port>
        </Control>
        <Action ID="SendNav2Goal">
            <input_port name="goal" type="std::string" default="0;0;0">Goal in format 'x;y;yaw' or 'x;y;z;yaw'</input_port>
            <input_port name="goal_pose" type="geometry_msgs::msg::PoseStamped_&lt;std::allocator&lt;void&gt; &gt;">PoseStamped goal from blackboard</input_port>
            <input_port name="frame_id" type="std::string" default="map">Frame ID for goal pose</input_port>
            <input_port name="action_name" type="std::string" default="">Action server name</input_port>
        </Action>
        <Condition ID="SetSentryCmd">
            <input_port name="confirm_respawn" type="bool" default="false">Confirm free respawn</input_port>
            <input_port name="confirm_pay_respawn" type="bool" default="false">Confirm paid respawn</input_port>
            <input_port name="projectile_allowance_to_exchange" type="int" default="0">Projectile allowance to exchange</input_port>
            <input_port name="remote_projectile_request_count" type="int" default="0">Remote projectile exchange request count</input_port>
            <input_port name="remote_hp_request_count" type="int" default="0">Remote hp exchange request count</input_port>
            <input_port name="posture_command" type="int" default="0">Posture command (1 attack, 2 defense, 3 move)</input_port>
            <input_port name="activate_rune" type="bool" default="false">Activate rune</input_port>
            <input_port name="topic_name" type="std::string" default="__default__placeholder__">Topic name</input_port>
        </Condition>
        <Decorator ID="TickAfterTimeout">
            <input_port name="timeout" type="float">time in s to wait before ticking child again</input_port>
        </Decorator>
    </TreeNodesModel>
</root>
